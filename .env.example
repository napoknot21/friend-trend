# Your OpenAI key, required if parsing texts using OpenAI models like gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-api-key-here

# Mailbox naming string for Outlook detection
EMAILBOX_SUFFIX=your-mailbox-suffix-here

# Optional internal markers used to exclude house briefs/newsletters
INTERNAL_ORG_PATTERNS=heroics capital,heroics-capital.com,heroics capital partners
INTERNAL_DIGEST_KEYWORDS=morning brief,daily brief,market brief

# Optional Ollama URL if you use the local provider
OLLAMA_URL=http://localhost:11434/api/generate

# Backend API bind settings
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# CORS
ALLOW_ALL_ORIGINS=true
# If ALLOW_ALL_ORIGINS=false, list explicit origins separated by commas
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.42:5173

# Frontend Vite dev server settings
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
VITE_DEV_OPEN=true

# Frontend -> backend API URL used by the dashboard
VITE_API_URL=http://127.0.0.1:8000

# Example LAN exposure:
# API_HOST=0.0.0.0
# VITE_DEV_HOST=0.0.0.0
# VITE_API_URL=http://192.168.1.42:8000
